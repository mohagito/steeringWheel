rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /boxes/{boxId} {
      allow read, write: if true;
    }
    match /adjustments/{adjustmentId} {
      allow read, write: if true;
    }
    match /users/{userId} {
      allow read, write: if true;
    }
    match /references/{referenceId} {
      allow read, write: if true;
    }
    match /deliveries/{deliveryId} {
      allow read, write: if true;
    }
    match /productions/{productionId} {
      allow read, write: if true;
    }
  }
}
